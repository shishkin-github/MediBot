# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemma-3-12b-it

# Proxy (single URL for both)
HTTP_PROXY=http://user:password@proxy.example.com:8080
HTTPS_PROXY=http://user:password@proxy.example.com:8080

# Polling
POLL_TIMEOUT_SEC=30
POLL_RETRY_DELAY_SEC=2

# Storage
SQLITE_PATH=/data/medibot.db

# Audio branch toggle
AUDIO_ENABLED=false

# Optional Telegram file_id values for audio (used only when AUDIO_ENABLED=true)
AUDIO_ID_HEAVY=
AUDIO_ID_LOST=
AUDIO_ID_NOTHING=
AUDIO_ID_MEANING=
AUDIO_ID_PRACTICE=
AUDIO_ID_CALM=

